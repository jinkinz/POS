// POS core schema — phase 1 (POS + menu + orders + payments + shifts).
// Conventions:
//  - All money as integer cents (sen/cents).
//  - All ids are UUIDs, client-generatable for offline creation.
//  - Every tenant-owned row carries companyId; outlet-scoped rows carry outletId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenancy ----------

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  country   Country
  currency  Currency
  timezone  String   @default("Asia/Kuala_Lumpur")
  createdAt DateTime @default(now())

  // Loyalty configuration: earn N points per whole RM/SGD spent,
  // each point redeems for M cents.
  loyaltyEarnPerCurrencyUnit Int @default(1)
  loyaltyRedeemCentsPerPoint Int @default(1)

  // Tax/e-invoice profile (LHDN MyInvois for MY; InvoiceNow later for SG)
  tin            String? // taxpayer identification number
  brn            String? // business registration number
  sstNo          String?
  msicCode       String? // 5-digit MSIC business activity code
  invoiceAddress String?

  einvoices EInvoice[]

  outlets  Outlet[]
  staff    Staff[]
  catalogs Category[]
  products Product[]
  modifierGroups ModifierGroup[]
  devices  Device[]
  ingredients Ingredient[]
  members  Member[]
}

model Outlet {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id])
  name      String
  address   String?
  active    Boolean @default(true)

  // Totals configuration (see @pos/shared TotalsConfig)
  serviceChargeBps     Int     @default(0)
  taxBps               Int     @default(0)
  taxInclusive         Boolean @default(false)
  serviceChargeTaxable Boolean @default(true)
  cashRounding         CashRounding @default(NONE)

  tables  DiningTable[]
  orders  Order[]
  shifts  Shift[]
  devices Device[]
  stockLevels    OutletIngredient[]
  stockMovements StockMovement[]

  @@index([companyId])
}

enum Country {
  MY
  SG
}

enum Currency {
  MYR
  SGD
}

enum CashRounding {
  NONE
  MY_5_SEN
}

// ---------- Staff (phase 1 minimal; HR module extends later) ----------

model Staff {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @db.Uuid
  company      Company   @relation(fields: [companyId], references: [id])
  name         String
  email        String?   @unique
  phone        String?
  role         StaffRole
  passwordHash String? // back office login
  pinHash      String? // POS terminal login
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  // Payroll setup
  salaryType         SalaryType?
  monthlySalaryCents Int?
  hourlyRateCents    Int?

  orders      Order[]
  shifts      Shift[]
  timeEntries TimeEntry[]

  @@index([companyId])
}

enum SalaryType {
  MONTHLY
  HOURLY
}

// ---------- HR: attendance & payroll ----------

model TimeEntry {
  id       String    @id @default(uuid()) @db.Uuid
  staffId  String    @db.Uuid
  staff    Staff     @relation(fields: [staffId], references: [id])
  outletId String    @db.Uuid
  clockIn  DateTime
  clockOut DateTime?
  /// Set when a manager creates/corrects the entry rather than a clock.
  manual   Boolean   @default(false)

  @@index([staffId, clockIn])
  @@index([outletId, clockIn])
}

model PayrollRun {
  id          String        @id @default(uuid()) @db.Uuid
  companyId   String        @db.Uuid
  month       String // YYYY-MM
  status      PayrollStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  finalizedAt DateTime?

  items PayrollItem[]

  @@unique([companyId, month])
}

enum PayrollStatus {
  DRAFT
  FINALIZED
}

model PayrollItem {
  id      String     @id @default(uuid()) @db.Uuid
  runId   String     @db.Uuid
  run     PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  staffId String     @db.Uuid
  staffName  String // snapshot
  salaryType SalaryType

  hoursWorked        Decimal? @db.Decimal(8, 2) // hourly staff
  grossCents         Int
  epfEmployeeCents   Int
  epfEmployerCents   Int
  socsoEmployeeCents Int
  socsoEmployerCents Int
  eisEmployeeCents   Int
  eisEmployerCents   Int
  pcbCents           Int      @default(0) // needs LHDN tables; 0 for now
  netCents           Int

  @@unique([runId, staffId])
}

enum StaffRole {
  OWNER
  MANAGER
  CASHIER
  WAITER
  KITCHEN
}

// ---------- Devices (POS terminals, kitchen displays, print bridges) ----------

// A registered device holds a long-lived token; staff then unlock it with
// their personal PIN to get a short-lived session bound to the device's outlet.
model Device {
  id        String     @id @default(uuid()) @db.Uuid
  companyId String     @db.Uuid
  company   Company    @relation(fields: [companyId], references: [id])
  outletId  String     @db.Uuid
  outlet    Outlet     @relation(fields: [outletId], references: [id])
  name      String // "Counter iPad 1"
  kind      DeviceKind
  tokenHash String     @unique // sha256 of the device token, shown once at registration
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  lastSeenAt DateTime?

  @@index([companyId])
}

enum DeviceKind {
  POS
  KDS
  PRINT_BRIDGE
  AGGREGATOR
}

// ---------- Catalog ----------

model Category {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id])
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  products Product[]

  @@index([companyId])
}

model Product {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @db.Uuid
  company    Company  @relation(fields: [companyId], references: [id])
  categoryId String?  @db.Uuid
  category   Category? @relation(fields: [categoryId], references: [id])
  name       String
  sku        String? // barcode / PLU for retail scanning
  basePriceCents Int
  imageUrl   String?
  kitchenStation String? // routing hint for KDS/kitchen printers (phase 2)
  active     Boolean  @default(true)
  soldOut    Boolean  @default(false) // the "86" flag, synced in real time
  /// Retail: sales deduct per-unit product stock (vs recipe ingredients).
  trackStock Boolean  @default(false)
  consignorId String? @db.Uuid
  consignor   Consignor? @relation(fields: [consignorId], references: [id])
  createdAt  DateTime @default(now())

  modifierGroups ProductModifierGroup[]
  orderItems     OrderItem[]
  recipeItems    RecipeItem[]
  stockLevels    ProductStock[]

  @@index([companyId, categoryId])
  @@index([companyId, sku])
}

// Per-outlet stock for trackStock (retail/consignment) products.
model ProductStock {
  outletId        String  @db.Uuid
  productId       String  @db.Uuid
  product         Product @relation(fields: [productId], references: [id])
  onHandQty       Int     @default(0)
  lowThresholdQty Int?

  @@id([outletId, productId])
}

model ProductStockMovement {
  id        String            @id @default(uuid()) @db.Uuid
  outletId  String            @db.Uuid
  productId String            @db.Uuid
  type      StockMovementType
  qtyDelta  Int
  reason    String?
  refId     String?           @db.Uuid
  staffId   String?           @db.Uuid
  createdAt DateTime          @default(now())

  @@index([outletId, productId, createdAt])
}

// ---------- Consignment ----------

// Someone whose goods you sell for a cut (bakers, craft sellers, ...).
model Consignor {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @db.Uuid
  name          String
  phone         String?
  email         String?
  /// Store's commission on consigned sales, e.g. 2000 = 20%.
  commissionBps Int      @default(2000)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  products    Product[]
  settlements ConsignmentSettlement[]

  @@index([companyId])
}

model ConsignmentSettlement {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  consignorId String    @db.Uuid
  consignor   Consignor @relation(fields: [consignorId], references: [id])
  periodStart DateTime
  periodEnd   DateTime

  unitsSold       Int
  salesCents      Int
  commissionCents Int
  payoutCents     Int // salesCents - commissionCents, owed to the consignor
  status          SettlementStatus @default(DRAFT)
  createdAt       DateTime         @default(now())
  paidAt          DateTime?

  @@unique([consignorId, periodStart])
  @@index([companyId])
}

enum SettlementStatus {
  DRAFT
  PAID
}

model ModifierGroup {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id])
  name      String // e.g. "Sugar level", "Add-ons"
  minSelect Int     @default(0)
  maxSelect Int     @default(1)

  modifiers Modifier[]
  products  ProductModifierGroup[]

  @@index([companyId])
}

model Modifier {
  id              String        @id @default(uuid()) @db.Uuid
  groupId         String        @db.Uuid
  group           ModifierGroup @relation(fields: [groupId], references: [id])
  name            String // e.g. "Less sugar", "Extra shot"
  priceDeltaCents Int           @default(0)
  soldOut         Boolean       @default(false)
  sortOrder       Int           @default(0)

  recipeItems ModifierRecipeItem[]

  @@index([groupId])
}

model ProductModifierGroup {
  productId String        @db.Uuid
  groupId   String        @db.Uuid
  product   Product       @relation(fields: [productId], references: [id])
  group     ModifierGroup @relation(fields: [groupId], references: [id])
  sortOrder Int           @default(0)

  @@id([productId, groupId])
}

// ---------- Tables ----------

model DiningTable {
  id       String  @id @default(uuid()) @db.Uuid
  outletId String  @db.Uuid
  outlet   Outlet  @relation(fields: [outletId], references: [id])
  name     String // "T12"
  zone     String? // "Patio"
  seats    Int     @default(2)
  qrToken  String  @unique @default(uuid()) // embedded in the printed QR code
  active   Boolean @default(true)

  orders Order[]

  @@unique([outletId, name])
}

// ---------- Orders ----------

model Order {
  id        String      @id @db.Uuid // client-generated UUID (offline creation)
  companyId String      @db.Uuid
  outletId  String      @db.Uuid
  outlet    Outlet      @relation(fields: [outletId], references: [id])
  tableId   String?     @db.Uuid
  table     DiningTable? @relation(fields: [tableId], references: [id])
  staffId   String?     @db.Uuid
  staff     Staff?      @relation(fields: [staffId], references: [id])
  memberId  String?     @db.Uuid
  member    Member?     @relation(fields: [memberId], references: [id])

  orderNo    Int? // per-outlet daily sequence, assigned server-side on sync
  type       OrderType
  source     OrderSource
  status     OrderStatus @default(OPEN)
  guestCount Int         @default(1)
  notes      String?

  subtotalCents      Int @default(0)
  discountCents      Int @default(0) // voucher discount, applied pre-tax
  serviceChargeCents Int @default(0)
  taxCents           Int @default(0)
  roundingCents      Int @default(0) // MY 5-sen cash rounding adjustment
  totalCents         Int @default(0)
  voucherId          String? @db.Uuid // personal voucher applied
  voucherCode        String? // code as entered (promo or personal)
  appliedCampaignId  String? @db.Uuid

  // Delivery-aggregator origin (GrabFood, foodpanda, ...)
  aggregatorProvider String?
  externalRef        String? // platform's order id — idempotency key
  customerName       String?

  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  voidReason String?

  items    OrderItem[]
  payments Payment[]
  gatewayPayments GatewayPayment[]

  @@unique([aggregatorProvider, externalRef])
  @@index([outletId, status])
  @@index([outletId, openedAt])
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  PICKUP
  DELIVERY
}

enum OrderSource {
  POS
  QR
  KIOSK
  AGGREGATOR
}

enum OrderStatus {
  OPEN
  COMPLETED
  VOIDED
}

model OrderItem {
  id        String  @id @db.Uuid // client-generated
  orderId   String  @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id])
  productId String? @db.Uuid
  product   Product? @relation(fields: [productId], references: [id])

  // Snapshots so historical orders survive menu edits/deletes
  nameSnapshot   String
  unitPriceCents Int
  quantity       Int
  /// [{groupName, modifierName, priceDeltaCents}]
  modifiersJson  Json    @default("[]")
  notes          String?

  status   OrderItemStatus @default(PENDING)
  courseNo Int             @default(1)
  station  String?

  voidReason String?
  createdAt  DateTime @default(now())

  @@index([orderId])
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  VOIDED
}

// Per-outlet daily sequence for human-facing order numbers.
// Incremented atomically inside the order-create transaction.
model OrderCounter {
  outletId String @db.Uuid
  bizDate  String // YYYY-MM-DD in the outlet's timezone
  counter  Int    @default(0)

  @@id([outletId, bizDate])
}

// ---------- Payments ----------

model Payment {
  id      String @id @db.Uuid // client-generated
  orderId String @db.Uuid
  order   Order  @relation(fields: [orderId], references: [id])

  method        PaymentMethod
  amountCents   Int
  tenderedCents Int? // cash given
  changeCents   Int?
  gatewayRef    String? // gateway/terminal transaction reference
  status        PaymentStatus @default(CAPTURED)
  paidAt        DateTime      @default(now())

  @@index([orderId])
}

enum PaymentMethod {
  CASH
  CARD
  QR_WALLET
  GIFT_CARD
  STORED_VALUE
  POINTS
  OTHER
}

enum PaymentStatus {
  PENDING
  CAPTURED
  REFUNDED
  FAILED
}

// ---------- Inventory ----------

// Ingredients are company-level; stock levels are per outlet.
// Quantities use Decimal(14,3) in the ingredient's base unit (g/ml/pcs).
model Ingredient {
  id        String         @id @default(uuid()) @db.Uuid
  companyId String         @db.Uuid
  company   Company        @relation(fields: [companyId], references: [id])
  name      String
  unit      IngredientUnit
  /// Cost per base unit (e.g. cents per gram), 4dp for cheap bulk goods.
  costCents Decimal        @default(0) @db.Decimal(12, 4)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  recipeItems         RecipeItem[]
  modifierRecipeItems ModifierRecipeItem[]
  stockLevels         OutletIngredient[]
  movements           StockMovement[]

  @@index([companyId])
}

enum IngredientUnit {
  G
  ML
  PCS
}

model OutletIngredient {
  outletId        String     @db.Uuid
  ingredientId    String     @db.Uuid
  outlet          Outlet     @relation(fields: [outletId], references: [id])
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  onHandQty       Decimal    @default(0) @db.Decimal(14, 3)
  lowThresholdQty Decimal?   @db.Decimal(14, 3)

  @@id([outletId, ingredientId])
}

// Product BOM: selling one unit of the product consumes these quantities.
model RecipeItem {
  productId    String     @db.Uuid
  ingredientId String     @db.Uuid
  product      Product    @relation(fields: [productId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  qty          Decimal    @db.Decimal(14, 3)

  @@id([productId, ingredientId])
}

// Modifier add-on BOM: "Extra egg" consumes 1 egg per unit sold.
model ModifierRecipeItem {
  modifierId   String     @db.Uuid
  ingredientId String     @db.Uuid
  modifier     Modifier   @relation(fields: [modifierId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  qty          Decimal    @db.Decimal(14, 3)

  @@id([modifierId, ingredientId])
}

// Append-only ledger. onHandQty is always the sum of a level's movements
// (plus its starting zero), so shrinkage investigations can replay history.
model StockMovement {
  id           String            @id @default(uuid()) @db.Uuid
  outletId     String            @db.Uuid
  ingredientId String            @db.Uuid
  outlet       Outlet            @relation(fields: [outletId], references: [id])
  ingredient   Ingredient        @relation(fields: [ingredientId], references: [id])
  type         StockMovementType
  qtyDelta     Decimal           @db.Decimal(14, 3)
  reason       String?
  refId        String?           @db.Uuid // e.g. the order id for sale deductions
  staffId      String?           @db.Uuid
  createdAt    DateTime          @default(now())

  @@index([outletId, ingredientId, createdAt])
}

enum StockMovementType {
  PURCHASE
  SALE_DEDUCT
  VOID_RETURN
  ADJUSTMENT
  WASTAGE
  STOCKTAKE
}

// A payment intent at an external gateway (dynamic QR / checkout). The
// customer-facing money state; a successful one produces a Payment row.
model GatewayPayment {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @db.Uuid
  outletId    String  @db.Uuid
  orderId     String  @db.Uuid
  order       Order   @relation(fields: [orderId], references: [id])
  provider    String // MOCK | HITPAY | FIUU | ...
  providerRef String? // the gateway's own id, unique per provider
  amountCents Int
  currency    Currency
  status      GatewayPaymentStatus @default(PENDING)
  qrData      String? // payload to render as a QR code
  checkoutUrl String?
  failReason  String?
  paymentId   String?  @db.Uuid // the Payment row created on success
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, providerRef])
  @@index([orderId])
}

enum GatewayPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
  CANCELED
}

// ---------- CRM / loyalty ----------

// Phone-number-first membership (how MY/SG F&B actually signs people up).
model Member {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id])
  phone     String
  name      String?
  email     String?
  active    Boolean  @default(true)
  /// PDPA: recorded when the member agreed to join the program.
  consentAt DateTime @default(now())

  pointsBalance      Int       @default(0)
  lifetimeSpendCents Int       @default(0)
  visits             Int       @default(0)
  lastVisitAt        DateTime?
  createdAt          DateTime  @default(now())

  transactions PointsTransaction[]
  orders       Order[]
  vouchers     Voucher[]

  @@unique([companyId, phone])
  @@index([companyId, name])
}

// A promotion. CODE = shared promo code usable maxUses times;
// ISSUED = template for personal one-time vouchers given to members.
model Campaign {
  id        String       @id @default(uuid()) @db.Uuid
  companyId String       @db.Uuid
  name      String
  kind      CampaignKind
  /// Shared promo code (CODE kind), unique per company.
  code             String?
  discountType     DiscountType
  valueCents       Int? // AMOUNT
  valueBps         Int? // PERCENT, e.g. 1000 = 10%
  maxDiscountCents Int?
  minSpendCents    Int          @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  maxUses          Int? // CODE kind
  usedCount        Int          @default(0)
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())

  vouchers Voucher[]

  @@unique([companyId, code])
  @@index([companyId])
}

enum CampaignKind {
  CODE
  ISSUED
}

enum DiscountType {
  AMOUNT
  PERCENT
}

// A personal one-time voucher issued from an ISSUED campaign.
model Voucher {
  id         String        @id @default(uuid()) @db.Uuid
  campaignId String        @db.Uuid
  campaign   Campaign      @relation(fields: [campaignId], references: [id])
  memberId   String?       @db.Uuid
  member     Member?       @relation(fields: [memberId], references: [id])
  code       String        @unique // e.g. V-8FK2QZ
  status     VoucherStatus @default(ISSUED)
  orderId    String?       @db.Uuid
  issuedAt   DateTime      @default(now())
  redeemedAt DateTime?

  @@index([memberId])
}

enum VoucherStatus {
  ISSUED
  REDEEMED
  CANCELLED
}

// Signed ledger — pointsBalance is always the sum of these.
model PointsTransaction {
  id       String       @id @default(uuid()) @db.Uuid
  memberId String       @db.Uuid
  member   Member       @relation(fields: [memberId], references: [id])
  type     PointsTxType
  points   Int // positive earn/adjust-up, negative redeem/adjust-down
  orderId  String?      @db.Uuid
  reason   String?
  createdAt DateTime    @default(now())

  @@index([memberId, createdAt])
  // At most one automatic earn per order (idempotent settlement hooks).
  @@unique([orderId, type])
}

enum PointsTxType {
  EARN
  REDEEM
  ADJUST
}

// ---------- E-invoicing ----------

// A document submitted (or to be submitted) to the tax authority.
// INDIVIDUAL = buyer-requested invoice for one order;
// CONSOLIDATED = monthly aggregate of B2C sales not individually invoiced.
model EInvoice {
  id        String         @id @default(uuid()) @db.Uuid
  companyId String         @db.Uuid
  company   Company        @relation(fields: [companyId], references: [id])
  type      EInvoiceType
  status    EInvoiceStatus @default(SUBMITTED)
  provider  String // MOCK | MYINVOIS

  orderId     String?   @unique @db.Uuid // individual invoices
  periodStart DateTime? // consolidated invoices
  periodEnd   DateTime?

  subtotalCents Int
  taxCents      Int
  totalCents    Int
  currency      Currency
  orderCount    Int      @default(1)

  buyerJson Json?
  docJson   Json // exactly what we submitted — the audit trail

  providerUuid String?
  longId       String?
  qrUrl        String?
  error        String?

  createdAt   DateTime  @default(now())
  submittedAt DateTime?
  validatedAt DateTime?

  @@unique([companyId, type, periodStart])
  @@index([companyId, createdAt])
}

enum EInvoiceType {
  INDIVIDUAL
  CONSOLIDATED
}

enum EInvoiceStatus {
  PENDING
  SUBMITTED
  VALID
  INVALID
  CANCELLED
}

// ---------- Printing ----------

// Structured print jobs; the on-site bridge renders them to ESC/POS.
model PrintJob {
  id        String         @id @default(uuid()) @db.Uuid
  companyId String         @db.Uuid
  outletId  String         @db.Uuid
  orderId   String?        @db.Uuid
  type      PrintJobType
  station   String? // kitchen ticket routing ("wok", "drinks", ...)
  payload   Json
  status    PrintJobStatus @default(PENDING)
  error     String?
  createdAt DateTime       @default(now())
  printedAt DateTime?

  @@index([outletId, status, createdAt])
}

enum PrintJobType {
  RECEIPT
  KITCHEN
  Z_REPORT
}

enum PrintJobStatus {
  PENDING
  PRINTED
  FAILED
}

// ---------- Shifts / cash management ----------

model Shift {
  id       String @id @default(uuid()) @db.Uuid
  outletId String @db.Uuid
  outlet   Outlet @relation(fields: [outletId], references: [id])
  staffId  String @db.Uuid
  staff    Staff  @relation(fields: [staffId], references: [id])

  openingFloatCents Int       @default(0)
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  expectedCashCents Int? // computed at close
  countedCashCents  Int? // blind count entered by staff
  notes             String?

  cashMovements CashMovement[]

  @@index([outletId, openedAt])
}

model CashMovement {
  id      String   @id @default(uuid()) @db.Uuid
  shiftId String   @db.Uuid
  shift   Shift    @relation(fields: [shiftId], references: [id])
  type    CashMovementType
  amountCents Int
  reason  String
  createdAt DateTime @default(now())

  @@index([shiftId])
}

enum CashMovementType {
  CASH_IN
  CASH_OUT
}
