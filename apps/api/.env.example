DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos?schema=public"
PORT=3000
# Required in production; a dev-only fallback is used otherwise.
JWT_SECRET="change-me-to-a-long-random-string"

# --- payment gateways ---
# Mock gateway: enabled automatically outside production for dev/demo.
MOCK_GATEWAY_SECRET="mock-secret"
# HitPay (SG/MY): adapter activates when both are set.
# HITPAY_API_KEY=""
# HITPAY_SALT=""
# HITPAY_SANDBOX="true"
# Public base URL of this API, used for gateway webhook callbacks.
# PUBLIC_API_URL="https://api.example.com"

# --- e-invoicing (LHDN MyInvois) ---
# Mock provider enabled automatically outside production.
# MOCK_EINVOICE_ENABLED="true"
# Real MyInvois adapter activates when both are set (sandbox by default).
# MYINVOIS_CLIENT_ID=""
# MYINVOIS_CLIENT_SECRET=""
# MYINVOIS_SANDBOX="true"
